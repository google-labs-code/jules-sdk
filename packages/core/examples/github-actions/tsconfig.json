{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@google/jules-sdk": ["./node_modules/@google/jules-sdk"]
    }
  },
  "include": ["index.ts", "parse-command.test.ts", "../_shared/**/*.ts"]
}
